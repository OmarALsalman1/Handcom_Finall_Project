# Copy this file to ".env" in the same folder and adjust values as needed.
# ".env" is gitignored, so each machine/deployment keeps its own copy.
# All values below are the same defaults the app falls back to if a
# variable is missing, so the project runs out of the box without a ".env".

# Django secret key. Generate a new one for any real deployment.
SECRET_KEY=django-insecure-change-me-for-production

# Debug mode. Set to False in production.
DEBUG=True

# Comma-separated list of allowed hosts/IPs. "*" allows any host.
ALLOWED_HOSTS=*

# AI assistant backend: "rule_based" (no API key needed) or "gemini".
AI_PROVIDER=rule_based

# Required only if AI_PROVIDER=gemini.
GEMINI_API_KEY=

# Gmail SMTP credentials used to send verification/OTP and password-reset
# emails. Leave blank to skip sending real emails (e.g. during development).
# If set, use a Gmail address and an App Password (not your normal password).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
